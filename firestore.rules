rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is authenticated and email verified
    function isVerifiedUser() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    // Helper: check if user is the owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if true; // Public - anyone can read user profiles
      allow create: if request.auth != null && isOwner(userId);
      allow update: if isVerifiedUser() && isOwner(userId);
      allow delete: if false;

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if request.auth != null; // Cloud Functions can create notifications for users
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // User posts
    match /userPosts/{postId} {
      allow read: if true; // Public - anyone can read posts
      allow create: if isVerifiedUser();
      allow update: if isVerifiedUser() &&
        resource.data.postUser == /databases/$(database)/documents/users/$(request.auth.uid);
      allow delete: if isVerifiedUser() &&
        resource.data.postUser == /databases/$(database)/documents/users/$(request.auth.uid);
    }

    // Draft posts
    match /draftPosts/{draftId} {
      allow read: if request.auth != null;
      allow create: if isVerifiedUser();
      allow update, delete: if isVerifiedUser();
    }

    // Story comments
    match /storyComments/{commentId} {
      allow read: if true; // Public - anyone can read comments
      allow create: if isVerifiedUser();
      allow update, delete: if false;
    }

    // Events
    match /events/{eventId} {
      allow read: if true; // Public - anyone can read events
      allow create, update: if isVerifiedUser();
      allow delete: if false;
    }

    // RSVP (top-level collection)
    match /rsvp/{rsvpId} {
      allow read: if true; // Public - anyone can read RSVPs (to see who's attending)
      allow create: if isVerifiedUser();
      allow update: if isVerifiedUser();
      allow delete: if false;
    }

    // Followers subcollection
    match /followers/{userId}/userFollowers/{followerId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null;
      allow update: if false;
    }

    // Following subcollection
    match /following/{userId}/userFollowing/{followingId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null;
      allow update: if false;
    }

    // Organizations (read-only for users)
    match /litterpickingOrganizations/{orgId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // Recent locations (place picker cache)
    match /recentLocations/{locationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Stats (read-only for users, can be updated by verified users via transactions)
    match /stats/{docId} {
      allow read: if true; // Public - anyone can read stats
      allow create: if false; // Created by Cloud Functions only
      allow update: if isVerifiedUser(); // Allow verified users to update via transactions
      allow delete: if false;
    }

    // Litter facts (read-only)
    match /litterFacts/{factId} {
      allow read: if true; // Public - anyone can read facts
      allow create, update, delete: if false;
    }

    // App config (read-only)
    match /appConfig/{docId} {
      allow read: if true; // Public - anyone can read config
      allow create, update, delete: if false;
    }

    // Email verification resend requests collection
    // This collection tracks when users request verification email resends for rate limiting
    match /emailVerificationRequests/{requestId} {
      // Users can only read their own resend request records
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;

      // Users can create resend requests only for themselves
      // The requestId MUST be the user's UID to ensure one record per user
      allow create: if request.auth != null &&
                       request.auth.uid == requestId &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasOnly(['userId', 'lastRequestTime', 'email']);

      // Users can update only their own resend request record
      // This is used to update the timestamp when requesting another resend
      allow update: if request.auth != null &&
                       request.auth.uid == requestId &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasOnly(['userId', 'lastRequestTime', 'email']);

      // Users can delete their own resend request record (cleanup)
      allow delete: if request.auth != null &&
                       request.auth.uid == requestId &&
                       resource.data.userId == request.auth.uid;
    }
  }
}
